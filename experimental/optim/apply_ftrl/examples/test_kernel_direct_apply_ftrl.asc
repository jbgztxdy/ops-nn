// ============================================================================
// ApplyFtrl — Kernel 直调 (<<<>>>) 可运行样例（ascend910b / DAV_2201，真实 NPU）
//
// ApplyFtrl 无 CANN 已部署 aclnn 接口、无 PyTorch 等价（GE 图模式 / TF 算子）。本样例
// 直接复用本算子 op_kernel/apply_ftrl_kernel.h 的 NsApplyFtrl::ApplyFtrl<T, PAD_TAIL, HAS_L1>
// 计算类（与正式构建编译的同一份 kernel 源码），通过 CUDA 风格 <<<>>> 在真实 NPU 上运行，
// 与 fp64 CPU golden 比对三个原地更新输出 var / accum / linear。
//
// 用例：dtype=FLOAT(fp32)、shape=[16]、l1>0（走完整 sign + 软阈值 + L1 gate 路径），
// 数据刻意取良态值域（accum>0 -> Ln 良定义；|linear_t| 远离 l1 与 0 -> 规避奇点 / 近零脆弱）。
//
// 三输出原地写回 ABI（与主线 arch35 一致）：var -> var_out 缓冲；accum / linear 经各自
// 输入 GM 原地写回（Ref Tensor）。
//
// 一键编译 + 运行见同目录 run.sh。更完整的多 dtype / 多 shape / 边界覆盖见本算子
// tests/ut/op_kernel（CPU 孪生直跑主线 kernel）与 tests/st/aclnnApplyFtrl/atk_ApplyFtrl.json（ATK 真机用例集）。
// ============================================================================

#include "kernel_operator.h"

// op_kernel/apply_ftrl_kernel.h 会 #include "apply_ftrl_tiling_key.h"，其 ASCENDC_TPL_SEL 宏会展开为
// host 侧模板键校验代码（含裸 printf），在统一 ASC 编译下与 aicore 的 AscendC::printf 冲突。
// tiling_key.h 仅是构建期 TilingKey 调度 schema，与 kernel 运行时数值无关；这里预置其 include
// guard，跳过该头文件 body，仅引入计算类 NsApplyFtrl::ApplyFtrl 与 ApplyFtrlTilingData。
#define APPLY_FTRL_TILING_KEY_H

#include "apply_ftrl_kernel.h"

// ----------------------------------------------------------------------------
// 设备侧：把 24B 的 ApplyFtrlTilingData（3×int64）从 GM 读入 local 结构体。
// ----------------------------------------------------------------------------
__aicore__ inline void LoadTiling(GM_ADDR tiling, ApplyFtrlTilingData& lt)
{
    AscendC::GlobalTensor<int64_t> tgm;
    tgm.SetGlobalBuffer(reinterpret_cast<__gm__ int64_t*>(tiling), 3);
    lt.totalElements = tgm.GetValue(0);
    lt.blockFactor = tgm.GetValue(1);
    lt.ubFactor = tgm.GetValue(2);
}

// ----------------------------------------------------------------------------
// 设备侧 __global__ 入口：fp32 / PAD_TAIL=0 / HAS_L1=1。
//   与主线 op_kernel/apply_ftrl.cpp 等价（此处不依赖构建期 codegen 的
//   GET_TILING_DATA_WITH_STRUCT，直接用 GlobalTensor 读 GM tiling）。
// ----------------------------------------------------------------------------
extern "C" __global__ __aicore__ void apply_ftrl_direct_fp32(
    GM_ADDR var, GM_ADDR accum, GM_ADDR linear, GM_ADDR grad, GM_ADDR lr,
    GM_ADDR l1, GM_ADDR l2, GM_ADDR lr_power, GM_ADDR var_out, GM_ADDR tiling)
{
    ApplyFtrlTilingData lt;
    LoadTiling(tiling, lt);
    NsApplyFtrl::ApplyFtrl<float, false, true> op;  // T=float, PAD_TAIL=0, HAS_L1=1
    op.Init(var, accum, linear, grad, lr, l1, l2, lr_power, var_out, &lt);
    op.Process();
}

// ============================================================================
// 以下为 host 侧（在同一 ASC 翻译单元内编译；acl 运行时 + <<<>>> 启动）。
// ============================================================================
#include "acl/acl.h"
#include <cstdint>
#include <cstdio>
#include <cstring>
#include <cmath>
#include <vector>

namespace {

constexpr int64_t kElemCount = 16;
constexpr int64_t kUbFactor = 512;          // 单核 UB chunk（256B/64 对齐）。
constexpr int64_t kDmaBlockElemFp32 = 8;    // 32B / sizeof(float)。

int64_t CeilDiv(int64_t a, int64_t b) { return (a + b - 1) / b; }
int64_t CeilAlign(int64_t a, int64_t b) { return CeilDiv(a, b) * b; }

// CPU golden（fp64 高精度参考；对标 spec.yaml math_semantics.formula / op_kernel 计算链）。
//   accum_new = accum + grad*grad
//   pow_new   = accum_new^(-lr_power) ; pow_old = accum^(-lr_power)
//   linear_t  = linear + grad - ((pow_new - pow_old)/lr) * var
//   quadratic = pow_new/lr + 2*l2
//   x_res     = sign(linear_t)*l1 - linear_t
//   var'      = (|linear_t| > l1) ? x_res/quadratic : 0
void CpuGolden(const float* var, const float* accum, const float* linear, const float* grad,
               float lr, float l1, float l2, float lrPower, int64_t n,
               std::vector<double>& gVar, std::vector<double>& gAccum, std::vector<double>& gLinear)
{
    gVar.resize(n);
    gAccum.resize(n);
    gLinear.resize(n);
    for (int64_t i = 0; i < n; ++i) {
        double v = var[i], a = accum[i], lin = linear[i], g = grad[i];
        double accumNew = a + g * g;
        double powNew = std::pow(accumNew, -static_cast<double>(lrPower));
        double powOld = std::pow(a, -static_cast<double>(lrPower));
        double linearT = lin + g - ((powNew - powOld) / lr) * v;
        double quad = powNew / lr + 2.0 * l2;
        double sgn = (linearT > 0.0) ? 1.0 : ((linearT < 0.0) ? -1.0 : 0.0);
        double xRes = sgn * l1 - linearT;
        double varNew = (std::fabs(linearT) > l1) ? (xRes / quad) : 0.0;
        gVar[i] = varNew;
        gAccum[i] = accumNew;
        gLinear[i] = linearT;
    }
}

// 浮点计算类社区标准（fp32 单标杆，对齐 spec.yaml numerical_tolerance）：
//   Threshold = 2^-13 ≈ 1.22e-4；PASS: MERE < Threshold 且 MARE < 10×Threshold。
//   近零 golden（|g| < 1e-3）改用绝对容差，避免分母趋零虚高相对误差。
struct CmpResult {
    double mere;
    double mare;
    double maxAbs;
    bool pass;
};

CmpResult Compare(const float* actual, const std::vector<double>& golden, int64_t n)
{
    constexpr double kThreshold = 1.0 / 8192.0;   // 2^-13
    constexpr double kNearZero = 1.0e-3;
    constexpr double kAtol = 1.0 / 8192.0;
    double sumRel = 0.0, maxRel = 0.0, maxAbs = 0.0;
    for (int64_t i = 0; i < n; ++i) {
        double a = static_cast<double>(actual[i]);
        double g = golden[i];
        double absErr = std::fabs(a - g);
        if (absErr > maxAbs) maxAbs = absErr;
        double rel;
        if (std::fabs(g) < kNearZero) {
            rel = (absErr <= kAtol) ? 0.0 : 1.0e9;  // 近零：绝对容差内记 0，否则触发 FAIL
        } else {
            rel = absErr / (std::fabs(g) + 1.0e-7);
        }
        sumRel += rel;
        if (rel > maxRel) maxRel = rel;
    }
    CmpResult r;
    r.mere = (n > 0) ? sumRel / static_cast<double>(n) : 0.0;
    r.mare = maxRel;
    r.maxAbs = maxAbs;
    r.pass = (r.mere < kThreshold) && (r.mare < 10.0 * kThreshold);
    return r;
}

bool ReadBack(void* dev, float* host, size_t bytes)
{
    return aclrtMemcpy(host, bytes, dev, bytes, ACL_MEMCPY_DEVICE_TO_HOST) == ACL_SUCCESS;
}

}  // namespace

int32_t main()
{
    // ------------------------------------------------------------------------
    // 1. 输入数据（shape=[16]，fp32，良态值域；accum>0、|linear_t| 远离 l1/0）。
    // ------------------------------------------------------------------------
    float hVar[kElemCount] = {
        1.00f, -1.00f, 0.50f, -0.50f, 0.10f, -0.10f, 0.80f,  2.00f,
       -2.00f,  0.05f, -0.05f, 3.50f, -3.50f, 0.30f, -0.30f, 0.25f};
    float hAccum[kElemCount] = {
        0.50f, 0.60f, 0.70f, 0.80f, 0.40f, 0.45f, 0.90f, 1.00f,
        1.10f, 0.35f, 0.36f, 0.55f, 0.65f, 0.50f, 0.52f, 0.60f};
    float hLinear[kElemCount] = {
        0.50f, -0.50f, 0.30f, -0.30f, 0.40f, -0.40f, 0.60f, -0.60f,
        0.70f, -0.70f, 0.45f, -0.45f, 0.55f, -0.55f, 0.35f, -0.35f};
    float hGrad[kElemCount] = {
        0.10f, -0.10f, 0.20f, -0.20f, 0.15f, -0.15f, 0.10f, -0.10f,
        0.20f, -0.20f, 0.05f, -0.05f, 0.12f, -0.12f, 0.08f, -0.08f};
    float hLr[1] = {0.1f};
    float hL1[1] = {0.01f};   // l1 > 0 -> 走 sign + 软阈值 + gate 完整路径
    float hL2[1] = {0.0f};
    float hLrPower[1] = {0.5f};

    // CPU golden（fp64）。
    std::vector<double> gVar, gAccum, gLinear;
    CpuGolden(hVar, hAccum, hLinear, hGrad, hLr[0], hL1[0], hL2[0], hLrPower[0],
              kElemCount, gVar, gAccum, gLinear);

    // ------------------------------------------------------------------------
    // 2. ACL 初始化（device 由 ASCEND_RT_VISIBLE_DEVICES 选择，本进程内逻辑 id=0）。
    // ------------------------------------------------------------------------
    if (aclInit(nullptr) != ACL_SUCCESS) { printf("[ERROR] aclInit failed\n"); return 1; }
    int32_t deviceId = 0;
    if (aclrtSetDevice(deviceId) != ACL_SUCCESS) { printf("[ERROR] aclrtSetDevice failed\n"); return 1; }

    int64_t coreNum = 0;
    if (aclrtGetDeviceInfo(deviceId, ACL_DEV_ATTR_VECTOR_CORE_NUM, &coreNum) != ACL_SUCCESS || coreNum <= 0) {
        printf("[ERROR] aclrtGetDeviceInfo(VECTOR_CORE_NUM) failed (num=%lld)\n", (long long)coreNum);
        aclrtResetDevice(deviceId);
        return 1;
    }

    // ------------------------------------------------------------------------
    // 3. 多核 tiling（DESIGN §3.3）：blockFactor 向上对齐 DMA 块，相邻核 GM 不重叠。
    // ------------------------------------------------------------------------
    ApplyFtrlTilingData tiling;
    tiling.totalElements = kElemCount;
    tiling.ubFactor = kUbFactor;
    int64_t blockFactor = CeilAlign(CeilDiv(kElemCount, coreNum), kDmaBlockElemFp32);
    if (blockFactor <= 0) blockFactor = kDmaBlockElemFp32;
    tiling.blockFactor = blockFactor;
    int64_t usedCoreNum = CeilDiv(kElemCount, blockFactor);
    if (usedCoreNum <= 0) usedCoreNum = 1;
    uint32_t blockNum = static_cast<uint32_t>(usedCoreNum);
    printf("[INFO] dtype=fp32 totalElements=%lld coreNum=%lld blockFactor=%lld usedCores=%u ubFactor=%lld\n",
           (long long)kElemCount, (long long)coreNum, (long long)blockFactor, blockNum, (long long)tiling.ubFactor);

    // ------------------------------------------------------------------------
    // 4. Device 内存分配 + Host->Device 拷贝。
    // ------------------------------------------------------------------------
    const size_t vecBytes = kElemCount * sizeof(float);
    const size_t scalarBytes = sizeof(float);

    uint8_t* dVar = nullptr; uint8_t* dAccum = nullptr; uint8_t* dLinear = nullptr; uint8_t* dGrad = nullptr;
    uint8_t* dLr = nullptr; uint8_t* dL1 = nullptr; uint8_t* dL2 = nullptr; uint8_t* dLrPower = nullptr;
    uint8_t* dVarOut = nullptr; uint8_t* dTiling = nullptr;

    auto mallocDev = [](uint8_t** p, size_t bytes) {
        return aclrtMalloc(reinterpret_cast<void**>(p), bytes, ACL_MEM_MALLOC_HUGE_FIRST) == ACL_SUCCESS;
    };
    bool ok = true;
    ok &= mallocDev(&dVar, vecBytes);     ok &= mallocDev(&dAccum, vecBytes);
    ok &= mallocDev(&dLinear, vecBytes);  ok &= mallocDev(&dGrad, vecBytes);
    ok &= mallocDev(&dLr, scalarBytes);   ok &= mallocDev(&dL1, scalarBytes);
    ok &= mallocDev(&dL2, scalarBytes);   ok &= mallocDev(&dLrPower, scalarBytes);
    ok &= mallocDev(&dVarOut, vecBytes);  ok &= mallocDev(&dTiling, sizeof(ApplyFtrlTilingData));
    if (!ok) { printf("[ERROR] aclrtMalloc failed\n"); aclrtResetDevice(deviceId); return 1; }

    auto h2d = [](uint8_t* dev, const void* host, size_t bytes) {
        return aclrtMemcpy(dev, bytes, host, bytes, ACL_MEMCPY_HOST_TO_DEVICE) == ACL_SUCCESS;
    };
    ok &= h2d(dVar, hVar, vecBytes);       ok &= h2d(dAccum, hAccum, vecBytes);
    ok &= h2d(dLinear, hLinear, vecBytes); ok &= h2d(dGrad, hGrad, vecBytes);
    ok &= h2d(dLr, hLr, scalarBytes);      ok &= h2d(dL1, hL1, scalarBytes);
    ok &= h2d(dL2, hL2, scalarBytes);      ok &= h2d(dLrPower, hLrPower, scalarBytes);
    ok &= h2d(dTiling, &tiling, sizeof(ApplyFtrlTilingData));
    if (!ok) { printf("[ERROR] aclrtMemcpy H2D failed\n"); aclrtResetDevice(deviceId); return 1; }

    aclrtStream stream = nullptr;
    if (aclrtCreateStream(&stream) != ACL_SUCCESS) { printf("[ERROR] create stream failed\n"); aclrtResetDevice(deviceId); return 1; }

    // ------------------------------------------------------------------------
    // 5. <<<>>> 启动 kernel（var -> var_out；accum / linear 原地写回各自输入 GM）。
    // ------------------------------------------------------------------------
    apply_ftrl_direct_fp32<<<blockNum, nullptr, stream>>>(
        dVar, dAccum, dLinear, dGrad, dLr, dL1, dL2, dLrPower, dVarOut, dTiling);

    if (aclrtSynchronizeStream(stream) != ACL_SUCCESS) {
        printf("[ERROR] aclrtSynchronizeStream failed\n");
        aclrtDestroyStream(stream);
        aclrtResetDevice(deviceId);
        return 1;
    }

    // ------------------------------------------------------------------------
    // 6. 回读三输出 + 精度比对。
    // ------------------------------------------------------------------------
    float npuVar[kElemCount] = {};
    float npuAccum[kElemCount] = {};
    float npuLinear[kElemCount] = {};
    ok = true;
    ok &= ReadBack(dVarOut, npuVar, vecBytes);     // var 来自 var_out 缓冲
    ok &= ReadBack(dAccum, npuAccum, vecBytes);    // accum 原地更新
    ok &= ReadBack(dLinear, npuLinear, vecBytes);  // linear 原地更新
    if (!ok) { printf("[ERROR] readback failed\n"); aclrtDestroyStream(stream); aclrtResetDevice(deviceId); return 1; }

    printf("ApplyFtrl Kernel-Direct Example (shape=[16], dtype=float32)\n");
    printf("  scalars: lr=%.4f l1=%.4f l2=%.4f lr_power=%.4f\n", hLr[0], hL1[0], hL2[0], hLrPower[0]);
    printf("  formula: accum'=accum+grad^2 ; linear_t=linear+grad-((accum'^-p - accum^-p)/lr)*var\n");
    printf("           quadratic=accum'^-p/lr + 2*l2 ; var'=(|linear_t|>l1)?(sign(linear_t)*l1-linear_t)/quadratic:0\n");
    printf("---------------------------------------------------------------------------------------------\n");
    printf("  %3s | %10s %10s %10s | %12s %12s %12s\n",
           "Idx", "var_npu", "accum_npu", "lin_npu", "var_gold", "accum_gold", "lin_gold");
    printf("---------------------------------------------------------------------------------------------\n");
    for (int64_t i = 0; i < kElemCount; ++i) {
        printf("  %3lld | %10.5f %10.5f %10.5f | %12.6f %12.6f %12.6f\n",
               (long long)i, npuVar[i], npuAccum[i], npuLinear[i], gVar[i], gAccum[i], gLinear[i]);
    }
    printf("---------------------------------------------------------------------------------------------\n");

    CmpResult cVar = Compare(npuVar, gVar, kElemCount);
    CmpResult cAccum = Compare(npuAccum, gAccum, kElemCount);
    CmpResult cLinear = Compare(npuLinear, gLinear, kElemCount);
    printf("  [var]    MERE=%.3e MARE=%.3e max_abs=%.3e -> %s\n", cVar.mere, cVar.mare, cVar.maxAbs, cVar.pass ? "PASS" : "FAIL");
    printf("  [accum]  MERE=%.3e MARE=%.3e max_abs=%.3e -> %s\n", cAccum.mere, cAccum.mare, cAccum.maxAbs, cAccum.pass ? "PASS" : "FAIL");
    printf("  [linear] MERE=%.3e MARE=%.3e max_abs=%.3e -> %s\n", cLinear.mere, cLinear.mare, cLinear.maxAbs, cLinear.pass ? "PASS" : "FAIL");

    bool allPass = cVar.pass && cAccum.pass && cLinear.pass;
    printf("=== RESULT: %s ===\n", allPass ? "PASS" : "FAIL");

    // ------------------------------------------------------------------------
    // 7. 资源释放。
    // ------------------------------------------------------------------------
    for (uint8_t* p : {dVar, dAccum, dLinear, dGrad, dLr, dL1, dL2, dLrPower, dVarOut, dTiling}) {
        if (p) aclrtFree(p);
    }
    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();
    return allPass ? 0 : 1;
}
