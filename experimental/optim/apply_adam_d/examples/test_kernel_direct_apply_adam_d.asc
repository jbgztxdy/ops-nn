/*!
 * \file test_kernel_direct_apply_adam_d.asc
 * \brief ApplyAdamD kernel 直调（<<<>>>）示例，真实 NPU（ascend910b / DAV_2201 / dav-2201）。
 *
 * ApplyAdamD 同时提供 aclnn 两段式接口与图模式调用；本示例保留 kernel 直调验证路径。
 * 端到端 GE/aclnn 运行依赖将自定义算子包部署到 OPP，本示例改用 kernel 直调直接验证算子计算：
 *   - 自包含：在 host 侧内部生成一组 FLOAT32 输入（var/m/v/grad 同形 [2,30] + 6 个标量），
 *     单核 <<<1>>> 调用真实内核 NsApplyAdamD::ApplyAdamD<T, NES>（#include op_kernel/apply_adam_d_kernel.h，
 *     不复制任何计算逻辑），把 NPU 输出与 host(FP32) golden 比对并打印。
 *   - 覆盖 use_nesterov=false / true 两条 var 更新分支（NES=0 / NES=1）。
 *
 * 编译：ASC / bisheng，--npu-arch=dav-2201（见同目录 CMakeLists.txt / run.sh）。
 */

#include <cmath>
#include <cstdint>
#include <cstdio>
#include <cstring>
#include <vector>
#include "acl/acl.h"
#include "apply_adam_d_tiling_data.h"
#include "kernel_operator.h"
#include "apply_adam_d_kernel.h" // 真实内核: NsApplyAdamD::ApplyAdamD<T,NES> + ApplyAdamDTilingData

// 薄 <<<>>> 入口：直接复用真实 kernel 类，不复制计算逻辑。
template <typename T, int NES>
__global__ __aicore__ void example_apply_adam_d(
    GM_ADDR var, GM_ADDR m, GM_ADDR v, GM_ADDR beta1Power, GM_ADDR beta2Power, GM_ADDR lr, GM_ADDR beta1, GM_ADDR beta2,
    GM_ADDR epsilon, GM_ADDR grad, GM_ADDR varOut, GM_ADDR mOut, GM_ADDR vOut, GM_ADDR tiling)
{
    __gm__ ApplyAdamDTilingData* tdGm = reinterpret_cast<__gm__ ApplyAdamDTilingData*>(tiling);
    ApplyAdamDTilingData td;
    td.totalNum = tdGm->totalNum;
    td.blockFactor = tdGm->blockFactor;
    td.ubFactor = tdGm->ubFactor;
    NsApplyAdamD::ApplyAdamD<T, NES> op;
    op.Init(var, m, v, beta1Power, beta2Power, lr, beta1, beta2, epsilon, grad, varOut, mOut, vOut, &td);
    op.Process();
}

#define CK(expr)                                \
    do {                                        \
        auto _r = (expr);                       \
        if (_r != ACL_SUCCESS) {                \
            printf(#expr " ret=%d\n", (int)_r); \
        }                                       \
    } while (0)

// host golden（FP32 内部计算，form B），与 op_kernel/apply_adam_d_kernel.h 计算路径一致。
static void GoldenFp32(
    const std::vector<float>& var, const std::vector<float>& m, const std::vector<float>& v,
    const std::vector<float>& grad, float b1p, float b2p, float lr, float b1, float b2, float eps, int nes,
    std::vector<float>& gv, std::vector<float>& gm, std::vector<float>& gvv)
{
    size_t n = var.size();
    float lrt = lr * std::sqrt(1.0f - b2p) / (1.0f - b1p);
    gv.resize(n);
    gm.resize(n);
    gvv.resize(n);
    for (size_t i = 0; i < n; ++i) {
        float mn = b1 * m[i] + (1.0f - b1) * grad[i];
        float vn = b2 * v[i] + (1.0f - b2) * grad[i] * grad[i];
        float num = nes ? (mn * b1 + (1.0f - b1) * grad[i]) : mn;
        gm[i] = mn;
        gvv[i] = vn;
        gv[i] = var[i] - lrt * num / (eps + std::sqrt(vn));
    }
}

// FP32 单 case：在真实 NPU 上 kernel 直调 + 与 golden 比对（rtol/atol = 1.22e-4）。
template <int NES>
static int RunFp32Case(const char* tag, aclrtStream stream)
{
    const int64_t n = 60; // var/m/v/grad 同形 [2,30]
    std::vector<float> var(n), m(n), v(n), grad(n);
    for (int64_t i = 0; i < n; ++i) {
        var[i] = 0.5f + 0.01f * static_cast<float>(i);
        m[i] = 0.1f + 0.002f * static_cast<float>(i);
        v[i] = 0.2f + 0.003f * static_cast<float>(i); // v >= 0，sqrt 合法
        grad[i] = -0.3f + 0.004f * static_cast<float>(i);
    }
    float scalars[6] = {0.9f, 0.999f, 0.001f, 0.9f, 0.999f, 1e-8f}; // b1p,b2p,lr,b1,b2,eps

    std::vector<float> gv, gm, gvv;
    GoldenFp32(
        var, m, v, grad, scalars[0], scalars[1], scalars[2], scalars[3], scalars[4], scalars[5], NES, gv, gm, gvv);

    const size_t tBytes = static_cast<size_t>(n) * sizeof(float);
    const size_t tCap = tBytes < 512 ? 512 : tBytes; // device buffer 下限，规避小块越界读
    const size_t sCap = 32;                          // 标量 32B slot（与 kernel DataCopyPad 一致）

    const float* tensorHost[4] = {var.data(), m.data(), v.data(), grad.data()}; // var,m,v,grad
    // 输入顺序：var, m, v, beta1_power, beta2_power, lr, beta1, beta2, epsilon, grad
    bool isScalar[10] = {false, false, false, true, true, true, true, true, true, false};

    std::vector<void*> dev(10, nullptr), hostBuf(10, nullptr);
    int tIdx = 0, sIdx = 0;
    for (int i = 0; i < 10; ++i) {
        size_t cap = isScalar[i] ? sCap : tCap;
        CK(aclrtMallocHost(&hostBuf[i], cap));
        memset(hostBuf[i], 0, cap);
        if (isScalar[i]) {
            *reinterpret_cast<float*>(hostBuf[i]) = scalars[sIdx++];
        } else {
            memcpy(hostBuf[i], tensorHost[tIdx++], tBytes);
        }
        CK(aclrtMalloc(&dev[i], cap, ACL_MEM_MALLOC_HUGE_FIRST));
        CK(aclrtMemcpy(dev[i], cap, hostBuf[i], cap, ACL_MEMCPY_HOST_TO_DEVICE));
    }
    void* dOut[3] = {nullptr, nullptr, nullptr};
    void* hOut[3] = {nullptr, nullptr, nullptr};
    for (int i = 0; i < 3; ++i) {
        CK(aclrtMalloc(&dOut[i], tCap, ACL_MEM_MALLOC_HUGE_FIRST));
        CK(aclrtMemset(dOut[i], tCap, 0, tCap));
        CK(aclrtMallocHost(&hOut[i], tCap));
    }

    // 单核 tiling：全部元素交给 core0（多核切分属 host tiling，由 op_host UT 覆盖）。
    ApplyAdamDTilingData td{};
    td.totalNum = n;
    td.blockFactor = n;
    td.ubFactor = 256;
    void* dTiling = nullptr;
    CK(aclrtMalloc(&dTiling, sizeof(ApplyAdamDTilingData), ACL_MEM_MALLOC_HUGE_FIRST));
    CK(aclrtMemcpy(
        dTiling, sizeof(ApplyAdamDTilingData), &td, sizeof(ApplyAdamDTilingData), ACL_MEMCPY_HOST_TO_DEVICE));

    example_apply_adam_d<float, NES><<<1, nullptr, stream>>>(
        (uint8_t*)dev[0], (uint8_t*)dev[1], (uint8_t*)dev[2], (uint8_t*)dev[3], (uint8_t*)dev[4], (uint8_t*)dev[5],
        (uint8_t*)dev[6], (uint8_t*)dev[7], (uint8_t*)dev[8], (uint8_t*)dev[9], (uint8_t*)dOut[0], (uint8_t*)dOut[1],
        (uint8_t*)dOut[2], (uint8_t*)dTiling);
    CK(aclrtSynchronizeStream(stream));

    for (int i = 0; i < 3; ++i) {
        CK(aclrtMemcpy(hOut[i], tBytes, dOut[i], tBytes, ACL_MEMCPY_DEVICE_TO_HOST));
    }

    // 比对（max relative error，分母 |g|+1e-7；rtol/atol=1.22e-4 浮点社区标准 fp32）。
    const float rtol = 1.220703125e-04f, atol = 1.220703125e-04f;
    const std::vector<float>* golden[3] = {&gv, &gm, &gvv};
    const char* names[3] = {"var", "m", "v"};
    bool pass = true;
    for (int o = 0; o < 3; ++o) {
        const float* act = reinterpret_cast<const float*>(hOut[o]);
        float maxRel = 0.0f, maxAbs = 0.0f;
        bool within = true;
        for (int64_t i = 0; i < n; ++i) {
            float g = (*golden[o])[i];
            float a = act[i];
            float ad = std::fabs(a - g);
            float rel = ad / (std::fabs(g) + 1e-7f);
            if (rel > maxRel)
                maxRel = rel;
            if (ad > maxAbs)
                maxAbs = ad;
            if (ad > atol + rtol * std::fabs(g))
                within = false;
        }
        bool ok = (maxRel < rtol) && within;
        pass = pass && ok;
        printf("  [%s] out=%s max_rel=%.3e max_abs=%.3e -> %s\n", tag, names[o], maxRel, maxAbs, ok ? "PASS" : "FAIL");
    }
    // 打印前 3 个 var 元素（NPU vs golden）作直观佐证。
    const float* actVar = reinterpret_cast<const float*>(hOut[0]);
    for (int64_t i = 0; i < 3 && i < n; ++i) {
        printf("  [%s] var[%ld]: npu=%.6f golden=%.6f\n", tag, i, actVar[i], gv[i]);
    }

    for (int i = 0; i < 10; ++i) {
        aclrtFree(dev[i]);
        aclrtFreeHost(hostBuf[i]);
    }
    for (int i = 0; i < 3; ++i) {
        aclrtFree(dOut[i]);
        aclrtFreeHost(hOut[i]);
    }
    aclrtFree(dTiling);
    return pass ? 0 : 1;
}

int32_t main(int32_t argc, char* argv[])
{
    printf("======== ApplyAdamD kernel 直调示例 (real NPU, dav-2201) ========\n");
    CK(aclInit(nullptr));
    int32_t deviceId = 0;
    CK(aclrtSetDevice(deviceId));
    aclrtStream stream = nullptr;
    CK(aclrtCreateStream(&stream));

    int rc = 0;
    printf("[case 1] dtype=float32 use_nesterov=false\n");
    rc |= RunFp32Case<0>("nes=0", stream);
    printf("[case 2] dtype=float32 use_nesterov=true\n");
    rc |= RunFp32Case<1>("nes=1", stream);

    CK(aclrtDestroyStream(stream));
    CK(aclrtResetDevice(deviceId));
    CK(aclFinalize());

    printf("======== 结果: %s (NPU=910B3) ========\n", rc == 0 ? "ALL PASS" : "FAILED");
    return rc;
}
